# SelfSurgeon Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Arize Phoenix Configuration
# For local development, use http://localhost:6006
# For cloud, use your Arize Phoenix endpoint
ARIZE_PHOENIX_HOST=http://localhost:6006
ARIZE_PHOENIX_PORT=6006

# Arize Cloud API Key (only required for cloud)
ARIZE_API_KEY=your_arize_key_if_cloud

# Google Cloud Project (for Agent Builder / ADK)
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_REGION=us-central1

# Application Settings
LOG_LEVEL=INFO
PHOENIX_PROJECT_NAME=selfsurgeon-victim
SURGERY_INTERVAL_SECONDS=300
DEPLOYMENT_THRESHOLD=0.05